        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	// Add your code here

	// Check if the reservation status is Checked In
	if (current.reservation_status == "checked_in") { 
		// Set state to Open - 1
		current.state = "1";
		current.update();
	} 
	// Check if the reservation status is No-Show or Cancelled
	else if (current.reservation_status == "no_show" || current.reservation_status == "cancelled") { 
		// Set state to Closed skipped - 7
		current.state = "7";
		current.update();
	} 
	// Check if the reservation status is Checked Out
	else if (current.reservation_status == "checked_out") { 
		// Set state to Closed complete - 3
		current.state = "3";
		current.update();
	} 

})(current, previous);]]></script>
