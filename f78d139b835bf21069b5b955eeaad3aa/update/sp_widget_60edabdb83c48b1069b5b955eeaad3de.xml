        <name>Workspace Reservation Spaces Alt</name>
        <option_schema/>
        <public>false</public>
        <roles/>
        <script><![CDATA[(function() {
  /* populate the 'data' object */
  /* e.g., data.table = $sp.getValue('table'); */

	var workspaceOptionsGr = new GlideRecord("x_1759267_wrm_workspace_options");
	workspaceOptionsGr.addQuery("status", "available");
	workspaceOptionsGr.query();
	data.total_spaces = workspaceOptionsGr.getRowCount();

	data.workspace_summary_list = [];

	while (workspaceOptionsGr.next()) {
		var type = workspaceOptionsGr.getValue("workspace_type");
		var type_name = workspaceOptionsGr.getDisplayValue("workspace_type");
		var name = workspaceOptionsGr.getValue("workspace_name");
		var location = workspaceOptionsGr.getDisplayValue("location");
		var status = workspaceOptionsGr.getDisplayValue("status");
		var max_occupancy = workspaceOptionsGr.getDisplayValue("max_occupancy");
		var image = workspaceOptionsGr.getDisplayValue("image");

		data.workspace_summary_list.push({
			workspace_name: name,
			workspace_type_name: type_name,
			location: location,
			status: status,
			capacity: max_occupancy,
			image: image
		});
	}

})();]]></script>
